# gollmproxy configuration (LiteLLM compatible format)

model_list:
  - model_name: gpt-4o
    litellm_params:
      model: openai/gpt-4o
      api_key: os.environ/OPENAI_API_KEY
      api_base: https://api.openai.com
  - model_name: gemini-flash
    litellm_params:
      model: gemini/gemini-2.5-flash
      api_key: os.environ/GEMINI_API_KEY

environment_variables:
  # OPENAI_API_KEY: "sk-..."
  # GEMINI_API_KEY: "AIza..."
  # TAVILY_API_KEY: "tvly-..."

general_settings:
  port: 8080
  log_file: "gollmproxy.log"
