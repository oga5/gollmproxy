# gollmproxy configuration

model_list:
  - model_name: gpt-4o
    litellm_params:
      model: openai/gpt-4o
      api_key: os.environ/OPENAI_API_KEY
      api_base: https://api.openai.com
  - model_name: gpt-4o-flex
    litellm_params:
      model: openai/gpt-4o
      api_key: os.environ/OPENAI_API_KEY
      extra_params:
        service_tier: flex
  - model_name: gemini-flash
    litellm_params:
      model: gemini/gemini-2.5-flash
      api_key: os.environ/GEMINI_API_KEY
  - model_name: gpt-oss-20b
    litellm_params:
      model: bedrock/openai.gpt-oss-20b-1:0
      region: ap-northeast-1
  - model_name: gpt-oss-20b-flex
    litellm_params:
      model: bedrock/openai.gpt-oss-20b-1:0
      region: ap-northeast-1
      extra_params:
        service_tier: flex
  - model_name: text-embedding-3-small
    litellm_params:
      model: openai/text-embedding-3-small
      api_key: os.environ/OPENAI_API_KEY
    model_info:
      mode: embedding
  - model_name: gemini-embedding
    litellm_params:
      model: gemini/text-embedding-004
      api_key: os.environ/GEMINI_API_KEY
    model_info:
      mode: embedding

environment_variables:
  # OPENAI_API_KEY: "sk-..."
  # GEMINI_API_KEY: "AIza..."
  # TAVILY_API_KEY: "tvly-..."
  # AWS_REGION: "ap-northeast-1"

general_settings:
  port: 8080
  log_file: "gollmproxy.log"
  log_request_body: true
  log_response_body: true
  bedrock_include_reasoning: false
  # pass_through_endpoints:
  #   - path: /custom-api
  #     target: https://api.example.com
  #     headers:
  #       Authorization: "Bearer os.environ/CUSTOM_API_KEY"
  #       X-Custom-Header: "some-value"
  #     forward_headers: true
